<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Scanner X-618-B | Ford Pines Edition AR</title>

    <!-- SEO & Social Meta Tags -->
    <meta name="description" content="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Augmented Reality paranormal scanner interface. [WORK IN PROGRESS - SYSTEM CALIBRATING]">
    <meta name="keywords" content="Augmented Reality, AR, Gravity Falls, Ford Pines, Scanner, Three.js, MindAR, Paranormal, Mystery">
    <meta name="author" content="F.P. // Augmented Reality Book project">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Scanner X-618-B | Ford Pines Edition AR">
    <meta property="og:description" content="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Explore the paranormal through augmented reality. [WORK IN PROGRESS]">
    <meta property="og:image" content="assets/social-share.png">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:title" content="Scanner X-618-B | Ford Pines Edition AR">
    <meta property="twitter:description" content="Augmented Reality paranormal scanner interface. [WORK IN PROGRESS]">
    <meta property="twitter:image" content="assets/social-share.png">

    <!-- System Icons -->
    <link rel="icon" type="image/svg+xml" href="assets/favicon.svg">

    <!-- System Dependencies -->
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=VT323&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>

    {% if env.isProduction %}
    <link rel="stylesheet" href="style/styles.min.css">
    {% else %}
    <link rel="stylesheet" href="style/styles.css">
    {% endif %}

    {% if not env.isProduction %}
    <script type="importmap">
        {
          "imports": {
            "three": "./javascript/three.module.js",
            "three/addons/": "./javascript/",
            "mind-ar-image-three": "https://cdn.jsdelivr.net/npm/mind-ar@1.2.5/dist/mindar-image-three.prod.js"
          }
        }
    </script>
    {% else %}
    <script type="importmap">
        {
          "imports": {
            "three": "https://cdn.jsdelivr.net/npm/three@0.147.0/build/three.module.js",
            "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.147.0/examples/jsm/",
            "mind-ar-image-three": "https://cdn.jsdelivr.net/npm/mind-ar@1.2.5/dist/mindar-image-three.prod.js"
          }
        }
    </script>
    {% endif %}
</head>

<body>
    <div id="scanner-ui">
        <h1 class="sr-only">Scanner X-618-B Augmented Reality Interface</h1>
        <div class="header-tray">
            <div class="corner-stamp">UNIT ID: X-618-B // REF: FORD P.</div>
            <div class="corner-stamp">WARNING: SCANNER MAY ATTRACT UNWANTED ATTENTION</div>
        </div>

        <div class="workspace">
            <div class="screen-assembly">
                <div id="fp-tag" class="tape-label">PROPERTY OF F.P.</div>
                <div id="serial-tag" class="tape-label">S/N: 06182012-G</div>

                <div class="crt-frame" id="crt-screen">
                    <div id="ar-container"></div>
                    <canvas id="wave-canvas"></canvas>
                    <div id="anomaly-overlay">ANOMALY DETECTED</div>
                    <div id="anomaly-dimmer"></div>
                    <div class="scanline"></div>
                    <div class="flicker"></div>

                    <div id="dev-console">
                        <!-- Ported from appV2.js buildDev -->
                    </div>

                </div>
            </div>

            <div class="side-panel">
                <div class="knob-assembly">
                    <div class="knob" id="knob-1"></div>
                    <div class="knob-label">Gain</div>
                </div>
                <div class="knob-assembly">
                    <div class="knob" id="knob-2"></div>
                    <div class="knob-label">Freq</div>
                </div>
                <div class="knob-assembly">
                    <div class="knob" id="knob-3"></div>
                    <div class="knob-label">Phase</div>
                </div>
            </div>
        </div>

        <div class="control-panel">
            <div class="cp-col">
                <button id="toggle-scan-btn" class="btn-gf">Engage Scanner</button>
            </div>

            <div class="cp-col cp-center">
                <svg class="six-fingered-hand" id="dev-toggle" viewBox="0 0 100 100">
                    <path
                        d="M50 95c-15 0-25-10-25-20V45c0-2 1-4 3-4s3 2 3 4v15c0 1 1 2 2 2s2-1 2-2V25c0-2 1-4 3-4s3 2 3 4v30c0 1 1 2 2 2s2-1 2-2V15c0-2 1-4 3-4s3 2 3 4v40c0 1 1 2 2 2s2-1 2-2V10c0-2 1-4 3-4s3 2 3 4v45c0 1 1 2 2 2s2-1 2-2V20c0-2 1-4 3-4s3 2 3 4v40c0 1 1 2 2 2s2-1 2-2V45c0-2 1-4 3-4s3 2 3 4v30c0 10-10 20-25 20z" />
                </svg>
            </div>

            <div class="cp-col cp-right">
                <button id="wipe-cache-btn" class="btn-gf">Wipe Cache</button>
            </div>
        </div>
    </div>

    <!-- Failure Alert Overlay -->
    <div id="failure-overlay" class="hidden">
        <div class="alert-box">
            <div class="alert-header">⚠️ SYSTEM INTERFERENCE DETECTED</div>
            <div class="alert-body">
                <p>The scanner's AR modules have been blocked by this device or browser.</p>
                <p id="error-details" class="glitch-text"></p>
                <div class="alert-advice">
                    <p><strong>REMEDY:</strong> Try using <strong>Chrome</strong> or ensure Camera permissions are granted.</p>
                </div>
            </div>
            <button id="close-failure-btn" class="btn-gf">Acknowledge</button>
        </div>
    </div>

    {% if env.isProduction %}
    <script type="module" src="javascript/app.min.js"></script>
    {% else %}
    <script type="module" src="javascript/app.js"></script>
    {% endif %}
</body>

</html>
